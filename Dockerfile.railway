FROM node:22-alpine

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

COPY NorthStar/pnpm-workspace.yaml NorthStar/pnpm-lock.yaml NorthStar/tsconfig.base.json ./
COPY NorthStar/packages/shared/ ./packages/shared/
COPY NorthStar/packages/server/ ./packages/server/

RUN pnpm install --frozen-lockfile

WORKDIR /app/packages/server

EXPOSE 4000

CMD ["pnpm", "start"]
