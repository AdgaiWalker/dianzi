{
  "version": 2,
  "installCommand": "echo skip install",
  "builds": [
    {
      "src": "api/index.cjs",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.cjs"
    },
    {
      "src": "/api/?",
      "dest": "/api/index.cjs"
    }
  ]
}
