FROM node:20-alpine AS build

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/shared/ ./packages/shared/
COPY packages/frontlife-web/ ./packages/frontlife-web/
COPY packages/admin-console/ ./packages/admin-console/

RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --frozen-lockfile || pnpm install
RUN pnpm --dir packages/frontlife-web build
RUN pnpm --dir packages/admin-console build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/packages/frontlife-web/dist/ /usr/share/nginx/html/frontlife/
COPY --from=build /app/packages/admin-console/dist/ /usr/share/nginx/html/admin/
